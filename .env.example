# Local dev: set after `npm run convex:dev` finishes (CLI prints the deployment URL).

NEXT_PUBLIC_CONVEX_URL=

# Vercel AI Gateway — create an API key in the Vercel dashboard (AI → AI Gateway → API Keys).
# Used by `app/api/ai/*` Route Handlers (`generateText` / `streamText`). Never expose this to the client.
# On Vercel deployments, OIDC can authenticate the gateway without this key; the key is still required for most local dev.
AI_GATEWAY_API_KEY=

# FareMon & image routes — model IDs for Vercel AI Gateway (server-only; never use NEXT_PUBLIC_*).
TEXT_MODEL=openai/gpt-4.1-mini
IMAGE_MODEL=openai/gpt-image-1-mini

# Vercel production builds: create a Production Deploy Key in Convex Dashboard →
# your production deployment → Settings → Generate Production Deploy Key, then add
# CONVEX_DEPLOY_KEY in Vercel (Production only). The build runs `npm run build:vercel`
# which deploys Convex functions then builds Next.js.
